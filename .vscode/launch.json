{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Build Plugin",
			"skipFiles": [
				"<node_internals>/**"
			],
			"program": "${workspaceFolder}/esbuild.config.mjs",
			"args": ["production"],
			"outFiles": [
				"${workspaceFolder}/**/*.js"
			]
		}
	]
}
